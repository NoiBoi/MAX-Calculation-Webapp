# Public Supabase project settings. These values are safe for browser use only
# when every application table is protected by Row Level Security.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Initial laboratory release is invitation-only by default.
NEXT_PUBLIC_AUTH_SIGNUPS_ENABLED=false

# Reserved for a future server-only administration milestone. Do not expose it
# with a NEXT_PUBLIC_ prefix and do not add it to ordinary authentication code.
SUPABASE_SERVICE_ROLE_KEY=
